{
  "$schema": "./src/config-schema.json",
  "feed": {
    "pageName": "for_you",
    "pageSize": 10,
    "maxPages": 20,
    "sources": [
      { "type": "recommend", "pageName": "for_you", "maxPages": 20 },
      { "type": "recommend", "pageName": "for_you", "recentlyAdded": true, "maxPages": 10 },
      { "type": "nearby", "maxPages": 10 }
    ]
  },
  "filters": {
    "includeKeywords": [
      "developer","Remote", "engineer", "fullstack", "full stack", "full-stack", "backend", "back end", "back-end",
      "frontend", "front end", "front-end", "software", "programmer", "coder", "web developer", "mobile developer",
      "android", "ios", "react", "react native", "vue", "angular", "next", "nextjs", "node", "nodejs", "express",
      "javascript", "typescript", "python", "java", "golang", "go developer", "php", "laravel", "codeigniter",
      "ruby", "rails", "rust", "kotlin", "swift", "flutter", "dart", "c#", ".net", "dotnet", "spring", "springboot",
      "django", "flask", "fastapi", "graphql", "rest api", "api developer", "microservices",
      "devops", "sre", "site reliability", "cloud", "aws", "gcp", "azure", "kubernetes", "docker", "terraform",
      "ci/cd", "platform engineer", "infrastructure", "system engineer", "system analyst", "systems engineer",
      "data engineer", "data scientist", "data analyst", "machine learning", "ml engineer", "ai engineer",
      "deep learning", "nlp", "computer vision", "big data", "etl", "data warehouse",
      "database", "dba", "sql", "postgres", "mysql", "mongodb", "redis",
      "qa", "quality assurance", "tester", "automation", "test engineer", "sdet",
      "security", "cybersecurity", "pentest", "penetration", "infosec", "blockchain", "web3", "smart contract",
      "embedded", "iot", "firmware", "game developer", "unity", "unreal",
      "technical", "it support", "it staff", "network engineer", "solution architect", "software architect",
      "tech lead", "engineering manager", "scrum master", "product engineer"
    ],
    "excludeKeywords": ["sales", "marketing", "intern"],
    "jobTypes": ["FULL_TIME", "CONTRACT"],
    "workArrangements": ["REMOTE", "HYBRID", "ONSITE"],
    "minYearsOfExperienceMax": 5,
    "remoteOnly": false,
    "skipApplied": true,
    "skipFraudFlagged": true
  },
  "limits": {
    "maxAppliesPerRun": 2000,
    "maxAppliesPerDay": 5000,
    "minDelaySeconds": 4,
    "maxDelaySeconds": 12
  },
  "answers": {
    "years_of_relevant_experience_v2": "More than 5 years",
    "skill_set_tools": "Expert",
    "skill_set_foreign_language_v2": ["Bahasa Indonesia", "English"],
    "expected_salary_idr": 7000000
  },
  "intro": {
    "enabled": true
  },
  "cron": {
    "schedule": "0 */2 * * *",
    "timezone": "Asia/Jakarta"
  }
}
